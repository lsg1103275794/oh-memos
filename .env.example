# ============================================================================
# MemOS 配置示例文件 (.env.example)
# ============================================================================
# 使用方法:
#   1. 复制此文件为 .env: cp .env.example .env
#   2. 修改 .env 中的配置值
#   3. 重启服务使配置生效
#
# 配置优先级: 命令行参数 > 环境变量(.env) > config.json
# ============================================================================

# ============================================================================
# 基础设置
# ============================================================================
TZ=Asia/Shanghai                                    # 时区
MOS_CUBE_PATH=./data/memos_cubes                    # 记忆立方体存储路径
MEMOS_BASE_PATH=.                                   # 项目根目录
MOS_ENABLE_DEFAULT_CUBE_CONFIG=true                 # 是否启用默认立方体配置

# ============================================================================
# API 服务器 & MCP 客户端 (必填)
# ============================================================================
MEMOS_URL=http://localhost:18000                    # MemOS API 地址
MEMOS_USER=dev_user                                 # 默认用户 ID
MEMOS_DEFAULT_CUBE=dev_cube                         # 默认记忆立方体 ID
MEMOS_CUBES_DIR=/path/to/your/memos_cubes           # 立方体目录完整路径 (请修改)

# 超时设置 (秒)
MEMOS_TIMEOUT_TOOL=120.0                            # 工具调用超时
MEMOS_TIMEOUT_STARTUP=30.0                          # 启动超时
MEMOS_TIMEOUT_HEALTH=5.0                            # 健康检查超时
MEMOS_API_WAIT_MAX=60.0                             # API 最大等待时间

# 功能开关
MEMOS_ENABLE_DELETE=false                           # 是否启用删除功能 (谨慎开启)
MEMOS_DEBUG=false                                   # 调试模式 (输出更详细日志)

# ============================================================================
# 记忆模式
# ============================================================================
# general_text = 扁平记忆 (仅向量搜索，不需要 Neo4j，适合轻量使用)
# tree_text = 知识图谱记忆 (Neo4j + 向量，支持关系推理，功能完整)
MOS_TEXT_MEM_TYPE=tree_text

# 图谱重组 (自动检测记忆间的因果/条件/关联/冲突关系)
# 开启需要: Neo4j + LLM API
MOS_ENABLE_REORGANIZE=true                          # 开启关系检测
MOS_REORGANIZE_TIMEOUT=1800                         # 关系检测超时 (秒)
MOS_REORGANIZE_MIN_GROUP=10                         # 触发检测的最小节点数

ASYNC_MODE=sync                                     # 同步/异步模式
MOS_TOP_K=7                                         # 检索返回的最大结果数

# ============================================================================
# Neo4j 图数据库 (tree_text 模式必填)
# ============================================================================
NEO4J_BACKEND=neo4j-community                       # 后端类型 (neo4j / neo4j-community)
NEO4J_URI=bolt://localhost:7687                     # Bolt 连接地址
NEO4J_HTTP_URL=http://localhost:7474/db/neo4j/tx/commit  # HTTP API 地址
NEO4J_USER=neo4j                                    # 用户名
NEO4J_PASSWORD=your_neo4j_password                  # 密码 (请修改)
NEO4J_DB_NAME=neo4j                                 # 数据库名
MOS_NEO4J_SHARED_DB=false                           # 是否共享数据库模式

# ============================================================================
# Qdrant 向量数据库 (必填)
# ============================================================================
# 本地模式 (推荐开发使用)
QDRANT_HOST=localhost                               # 主机地址
QDRANT_PORT=6333                                    # 端口

# 云模式 (生产环境，使用时注释掉上面的 HOST/PORT)
# QDRANT_URL=https://your-cluster.cloud.qdrant.io   # 云服务地址
# QDRANT_API_KEY=your_qdrant_api_key                # API 密钥

# ============================================================================
# LLM 配置 (tree_text 模式必填，用于记忆提炼)
# ============================================================================
# 支持的提供商: openai, ollama
# 可使用 OpenAI 兼容 API (如 vLLM, LocalAI, SiliconFlow 等)
MOS_CHAT_MODEL_PROVIDER=openai                      # 提供商
MOS_CHAT_MODEL=gpt-4o-mini                          # 模型名称
OPENAI_API_KEY=sk-your_openai_api_key               # API 密钥 (请修改)
OPENAI_API_BASE=https://api.openai.com/v1           # API 基础地址
MOS_CHAT_TEMPERATURE=0.8                            # 温度参数 (0-1)
MOS_MAX_TOKENS=6000                                 # 最大 token 数
MOS_TOP_P=0.9                                       # Top-P 采样参数

# Ollama 本地模式 (取消注释以使用本地 LLM)
# MOS_CHAT_MODEL_PROVIDER=ollama
# MOS_CHAT_MODEL=llama3
# OLLAMA_API_BASE=http://localhost:11434

# ============================================================================
# MemReader LLM (用于检索，可与上面使用相同配置)
# ============================================================================
MEMRADER_MODEL=gpt-4o-mini
MEMRADER_API_KEY=sk-your_openai_api_key             # 请修改
MEMRADER_API_BASE=https://api.openai.com/v1
MEMRADER_MAX_TOKENS=6000

# ============================================================================
# 嵌入模型 (必填)
# ============================================================================
EMBEDDING_DIMENSION=1024                            # 嵌入向量维度
MOS_EMBEDDER_BACKEND=universal_api                  # 后端类型
MOS_EMBEDDER_PROVIDER=openai                        # API 提供商
MOS_EMBEDDER_MODEL=text-embedding-3-small           # 模型名称
MOS_EMBEDDER_API_BASE=https://api.openai.com/v1     # API 地址
MOS_EMBEDDER_API_KEY=sk-your_embedding_api_key      # API 密钥 (请修改)

# ============================================================================
# 重排序模型 (推荐配置，提升检索质量)
# ============================================================================
MOS_RERANKER_BACKEND=universal_api                  # 后端类型
MOS_RERANKER_URL=https://api.siliconflow.cn/v1      # API 地址
MOS_RERANKER_MODEL=netease-youdao/bce-reranker-base_v1  # 模型名称
MOS_RERANKER_API_KEY=sk-your_reranker_api_key       # API 密钥 (请修改)
MOS_RERANKER_HEADERS_EXTRA=                         # 额外请求头 (通常为空)
MOS_RERANKER_STRATEGY=single_turn                   # 重排策略

# ============================================================================
# 以下为可选配置，按需启用
# ============================================================================

# 互联网搜索 (可选)
ENABLE_INTERNET=false                               # 是否启用互联网搜索
BOCHA_API_KEY=                                      # 搜索 API 密钥
SEARCH_MODE=fast                                    # 搜索模式
FINE_STRATEGY=rewrite                               # 精细策略

# 偏好记忆 (可选)
ENABLE_PREFERENCE_MEMORY=true                       # 是否启用偏好记忆
PREFERENCE_ADDER_MODE=fast                          # 添加模式
DEDUP_PREF_EXP_BY_TEXTUAL=false                     # 文本去重

# MemReader 分块设置
MEM_READER_BACKEND=simple_struct                    # 后端类型
MEM_READER_CHAT_CHUNK_TYPE=default                  # 分块类型
MEM_READER_CHAT_CHUNK_TOKEN_SIZE=1600               # 分块 token 大小
MEM_READER_CHAT_CHUNK_SESS_SIZE=10                  # 会话分块大小
MEM_READER_CHAT_CHUNK_OVERLAP=2                     # 分块重叠

# 调度器 (可选，高级功能)
MOS_ENABLE_SCHEDULER=false                          # 是否启用调度器
MOS_SCHEDULER_TOP_K=10
MOS_SCHEDULER_ACT_MEM_UPDATE_INTERVAL=300
MOS_SCHEDULER_CONTEXT_WINDOW_SIZE=5
MOS_SCHEDULER_THREAD_POOL_MAX_WORKERS=10000
MOS_SCHEDULER_CONSUME_INTERVAL_SECONDS=0.01
MOS_SCHEDULER_ENABLE_PARALLEL_DISPATCH=true
MOS_SCHEDULER_ENABLE_ACTIVATION_MEMORY=false
API_SCHEDULER_ON=true
API_SEARCH_WINDOW_SIZE=5
API_SEARCH_HISTORY_TURNS=5
MEMSCHEDULER_USE_REDIS_QUEUE=false

# Milvus (可选，用于偏好记忆)
MILVUS_URI=http://localhost:19530
MILVUS_USER_NAME=root
MILVUS_PASSWORD=your_milvus_password

# Redis (可选，用于调度器队列)
MEMSCHEDULER_REDIS_HOST=localhost
MEMSCHEDULER_REDIS_PORT=6379
MEMSCHEDULER_REDIS_DB=0
MEMSCHEDULER_REDIS_PASSWORD=
MEMSCHEDULER_REDIS_TIMEOUT=5
MEMSCHEDULER_REDIS_CONNECT_TIMEOUT=5

# RabbitMQ (可选)
MEMSCHEDULER_RABBITMQ_HOST_NAME=
MEMSCHEDULER_RABBITMQ_USER_NAME=
MEMSCHEDULER_RABBITMQ_PASSWORD=
MEMSCHEDULER_RABBITMQ_VIRTUAL_HOST=memos
MEMSCHEDULER_RABBITMQ_ERASE_ON_CONNECT=true
MEMSCHEDULER_RABBITMQ_PORT=5672

# Nacos (可选，服务发现)
NACOS_ENABLE_WATCH=false
NACOS_WATCH_INTERVAL=60
NACOS_SERVER_ADDR=
NACOS_DATA_ID=
NACOS_GROUP=DEFAULT_GROUP
NACOS_NAMESPACE=
AK=
SK=

# OpenCode API (可选)
OPENCODE_API_KEY=
OPENCODE_API_BASE=
OPENCODE_MODEL=opencode/glm-4.7-free
