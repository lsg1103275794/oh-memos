# ============================================================================
# oh-memos-mcp Environment Configuration
# ============================================================================
# Copy this file to .env in your project root and adjust values.
# Priority: CLI args > environment variables > defaults
# ============================================================================

# --- Required ---
MEMOS_URL=http://localhost:18000        # oh-memos API address
MEMOS_USER=dev_user                     # Default user ID
MEMOS_DEFAULT_CUBE=dev_cube             # Default memory cube ID
MEMOS_CUBES_DIR=/path/to/cubes          # Absolute path to cubes directory

# --- Timeouts (seconds) ---
# MEMOS_TIMEOUT_TOOL=300                # Tool call timeout (default: 300)
# MEMOS_TIMEOUT_STARTUP=30              # Startup timeout (default: 30)
# MEMOS_TIMEOUT_HEALTH=5                # Health check timeout (default: 5)
# MEMOS_API_WAIT_MAX=60                 # Max API wait time (default: 60)

# --- Feature Flags ---
# MEMOS_ENABLE_DELETE=false             # Enable memory deletion (default: false)
# MEMOS_LOG_LEVEL=WARNING               # DEBUG | INFO | WARNING | ERROR

# --- Neo4j (optional, for direct graph queries) ---
# NEO4J_HTTP_URL=http://localhost:7474
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_password
