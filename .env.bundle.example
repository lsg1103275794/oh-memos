# ==============================================================================
# MemOS Bundle 配置文件
# MemOS Bundle Configuration
# ==============================================================================
# 只需修改 LLM API 部分，其他保持默认
# Only modify the LLM API section, keep others as default
# ==============================================================================

## ========== 必须配置 (Required) ==========

# ----------------------------------------
# 选项1: 使用 OpenAI 或兼容 API
# Option 1: OpenAI or compatible API
# ----------------------------------------
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
MOS_CHAT_MODEL=gpt-4o-mini
MOS_EMBEDDER_API_KEY=sk-your-api-key-here

# ----------------------------------------
# 选项2: 使用本地 Ollama（取消注释以启用）
# Option 2: Local Ollama (uncomment to enable)
# ----------------------------------------
# MOS_CHAT_MODEL_PROVIDER=ollama
# MOS_CHAT_MODEL=llama3
# MOS_EMBEDDER_BACKEND=ollama
# MOS_EMBEDDER_MODEL=nomic-embed-text

## ========== 以下保持默认 (Keep Default) ==========

# ----------------------------------------
# 基础配置 Basic Configuration
# ----------------------------------------
TZ=Asia/Shanghai
MOS_CUBE_PATH=./data/memos_cubes
MOS_TEXT_MEM_TYPE=tree_text

# ----------------------------------------
# Neo4j 配置（整合包内置）
# Neo4j Configuration (Built-in)
# ----------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memos_bundle_2024

# ----------------------------------------
# Qdrant 配置（整合包内置）
# Qdrant Configuration (Built-in)
# ----------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ----------------------------------------
# Embedding Fallback 配置
# 云端 API 失败时自动回退到本地 Ollama
# Auto fallback to local Ollama when cloud API fails
# ----------------------------------------
MOS_EMBEDDER_FALLBACK_ENABLED=true
MOS_EMBEDDER_FALLBACK_BACKEND=ollama
MOS_EMBEDDER_FALLBACK_MODEL=nomic-embed-text:latest

# ----------------------------------------
# API 服务配置
# API Service Configuration
# ----------------------------------------
MOS_API_HOST=0.0.0.0
MOS_API_PORT=18000

# ----------------------------------------
# 日志配置
# Logging Configuration
# ----------------------------------------
MOS_LOG_LEVEL=INFO

# ----------------------------------------
# MCP Server 配置
# MCP Server Configuration
# ----------------------------------------
MEMOS_URL=http://localhost:18000
MEMOS_CUBES_DIR=./data/memos_cubes
