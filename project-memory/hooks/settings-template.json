{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Copy the hooks section into your ~/.claude/settings.json. Adjust paths to match your MemOS install location.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_user_prompt.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_block_sensitive.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "tool == \"Bash\" && tool_input.command matches \"mkdir.*memory\"",
        "hooks": [
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_block_mkdir_memory.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_log_commands.js",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_auto_save.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_notify_milestone.js",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_auto_save.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_pre_compact.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node <MEMOS_PATH>/project-memory/hooks/node/memos_session_start.js"
          }
        ]
      }
    ]
  }
}
